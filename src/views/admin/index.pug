extends ../layouts/main-layout.pug

block content
  .container.is-fluid
    main(style="padding: 1.5rem 0")
      .columns.is-centered 
        .column.is-half
          .title
            span.has-text-warning Admin 
            span.has-text-grey-dark Section
          p.subtitle.has-text-grey  Choose a category to manage
          .columns.is-multiline
            a.column(href="/admin/products").column.is-one-quarter
              .notification.is-warning
                span.icon-text
                  span.icon
                    i.fas.fa-box
                  span Products
            a.column(href="/admin/users").is-one-quarter
              .notification.is-warning
                span.icon-text
                  span.icon
                    i.fas.fa-user
                  span Users
            a.column(href="/admin/users").is-one-quarter
              .notification.is-warning
                span.icon-text
                  span.icon
                    i.fas.fa-shopping-cart
                  span Orders
            a.column(href="/admin/users").is-one-quarter
              .notification.is-warning
                span.icon-text
                  span.icon
                    i.fas.fa-truck
                  span Transport
            a.column(href="/admin/users").is-one-quarter
              .notification.is-warning
                span.icon-text
                  span.icon
                    i.fas.fa-handshake
                  span Partners
            a.column(href="/admin/users").is-one-quarter
              button.button.is-warning(style="padding: 1.25rem 2.5rem 1.25rem 1.5rem")
                span.icon-text
                  span.icon
                    i.fas.fa-handshake
                  span Partners